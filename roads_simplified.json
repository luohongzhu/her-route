import { useEffect, useRef, useState } from 'react';
import { MapContainer, TileLayer, Polyline, Marker, Popup, useMap } from 'react-leaflet';
import type { Map as LeafletMap } from 'leaflet';
import L from 'leaflet';
import 'leaflet/dist/leaflet.css';

// Fix Leaflet default marker icon
delete (L.Icon.Default.prototype as any)._getIconUrl;
L.Icon.Default.mergeOptions({
    iconRetinaUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.7.1/images/marker-icon-2x.png',
    iconUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.7.1/images/marker-icon.png',
    shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.7.1/images/marker-shadow.png',
});

interface HerRouteMapProps {
    nightMode: boolean;
    routeGenerated: boolean;
    onSegmentClick: (segmentId: number) => void;
    onMapReady: (resetFn: () => void) => void;
}

// Map Constants
const MCMASTER_CENTER: [number, number] = [43.2609, -79.9192];
const WILSON_HALL: [number, number] = [43.26230329628743, -79.91706003190853];
const FAKE_HOUSE_DESTINATION: [number, number] = [43.2621167, -79.9121594]; // 87 Dalewood Crescent

/**
 * HARDCODED REAL ROAD ROUTE
 * Following actual street nodes from your JSON data to avoid walking through grass/buildings.
 */
const HARDCODED_WALK_PATH: [number, number][] = [
    WILSON_HALL,                                // Start at Wilson
    [43.2622775, -79.9176888],                   // Sterling St @ Campus interior
    [43.2622505, -79.9187404],                   // Sterling St Exit
    [43.2610, -79.9180],                         // Heading south towards Main
    [43.2595, -79.9200],                         // Intersection at Main St W
    [43.2592089, -79.9075417],                   // Arkell St segment
    [43.2589016, -79.9104077],                   // Arkell St @ Dalewood Intersection
    FAKE_HOUSE_DESTINATION                      // Arrive at 87 Dalewood Cres
];

const getSafetyColor = (score: number): string => {
    if (score >= 80) return '#ec4899';
    if (score >= 70) return '#f472b6';
    if (score >= 60) return '#f9a8d4';
    if (score >= 50) return '#fbcfe8';
    return '#fdf2f8';
};

const createPinkMarker = (label: string) => {
    return L.divIcon({
        className: 'custom-pink-marker',
        html: `
      <div style="width: 30px; height: 30px; background: #ec4899; border-radius: 50% 50% 50% 0; transform: rotate(-45deg); border: 3px solid white; box-shadow: 0 4px 6px rgba(0,0,0,0.3); display: flex; align-items: center; justify-content: center;">
        <div style="transform: rotate(45deg); color: white; font-size: 14px; font-weight: bold;">${label}</div>
      </div>`,
        iconSize: [30, 30],
        iconAnchor: [15, 30],
    });
};

function MapController({ onMapReady }: { onMapReady: (resetFn: () => void) => void }) {
    const map = useMap();
    useEffect(() => {
        const resetView = () => map.setView(MCMASTER_CENTER, 15);
        onMapReady(resetView);
    }, [map, onMapReady]);
    return null;
}

export default function HerRouteMap({
    nightMode,
    routeGenerated,
    onSegmentClick,
    onMapReady,
}: HerRouteMapProps) {
    const mapRef = useRef<LeafletMap | null>(null);
    const [allRoads, setAllRoads] = useState<any[]>([]);
    const [showAllRoads, setShowAllRoads] = useState(true);

    useEffect(() => {
        // Fetching the roads you provided
        fetch('/roads_simplified.json')
            .then(res => res.json())
            .then(data => {
                const roadsWithScores = data.map((road: any) => ({
                    ...road,
                    safetyScore: Math.floor(40 + Math.random() * 55),
                }));
                setAllRoads(roadsWithScores);
            })
            .catch(() => console.warn("Road data not found, check public folder."));
    }, []);

    return (
        <>
            <style>{`
                .leaflet-tile-pane {
                    filter: ${nightMode 
                        ? 'brightness(0.3) contrast(1.1) saturate(3.8) hue-rotate(120deg)' 
                        : 'saturate(2.3) brightness(1.05) hue-rotate(5deg)'};
                    transition: filter 0.3s ease;
                }
                .leaflet-marker-pane, .leaflet-popup-pane, .custom-pink-marker { filter: none !important; }
                .leaflet-overlay-pane svg { filter: none !important; }
            `}</style>
            
            <button
                onClick={() => setShowAllRoads(!showAllRoads)}
                className="fixed bottom-6 left-6 z-[9999] px-4 py-2 rounded-full shadow-xl font-bold text-xs bg-white text-pink-500 border-2 border-pink-500 hover:bg-pink-500 hover:text-white transition-all"
            >
                {showAllRoads ? 'HIDE SAFETY MAP' : 'SHOW SAFETY MAP'}
            </button>
            
            <div style={{ height: '100%', width: '100%' }}>
                <MapContainer
                    center={MCMASTER_CENTER}
                    zoom={15}
                    ref={mapRef}
                    style={{ height: '100%', width: '100%', zIndex: 1 }}
                >
                    <TileLayer url="https://tiles.stadiamaps.com/tiles/alidade_smooth/{z}/{x}/{y}{r}.png" />
                    <MapController onMapReady={onMapReady} />

                {/* Safety Overlay (All Roads) */}
                {showAllRoads && allRoads.map((road, idx) => (
                    <Polyline
                        key={`road-${idx}`}
                        positions={road.coordinates}
                        pathOptions={{
                            color: getSafetyColor(road.safetyScore),
                            weight: 3,
                            opacity: 0.4,
                        }}
                    />
                ))}

                {/* The Hardcoded Route to the House */}
                {routeGenerated && (
                    <>
                        {/* THE MAIN PINK LINE */}
                        <Polyline
                            positions={HARDCODED_WALK_PATH}
                            pathOptions={{
                                color: '#ec4899',
                                weight: 7,
                                opacity: 1,
                                lineCap: 'round',
                                lineJoin: 'round'
                            }}
                        />
                        
                        {/* Glow effect for the route */}
                        <Polyline
                            positions={HARDCODED_WALK_PATH}
                            pathOptions={{
                                color: '#ec4899',
                                weight: 12,
                                opacity: 0.3,
                            }}
                        />

                        {/* Start Marker */}
                        <Marker position={WILSON_HALL} icon={createPinkMarker('🏛️')}>
                            <Popup><strong>Wilson Hall</strong><br/>Starting Point</Popup>
                        </Marker>

                        {/* House Marker */}
                        <Marker position={FAKE_HOUSE_DESTINATION} icon={createPinkMarker('🏠')}>
                            <Popup>
                                <div className="text-center">
                                    <strong className="text-pink-600">Home</strong><br />
                                    <span>87 Dalewood Crescent</span>
                                </div>
                            </Popup>
                        </Marker>
                    </>
                )}
            </MapContainer>
            </div>
        </>
    );
}